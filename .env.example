# ── AI / LLM ─────────────────────────────────────────────
# Anthropic Claude — primary AI for all 12 agents (claude-sonnet-4-6 / claude-haiku-4-5)
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — fallback AI when Anthropic key is not set
OPENAI_API_KEY=sk-...

# Codebase Visualizer mapper model (defaults to claude-sonnet-4-6)
OPENRX_MAPPER_MODEL=claude-sonnet-4-6
OPENRX_MAPPER_INPUT_USD_PER_M=3
OPENRX_MAPPER_OUTPUT_USD_PER_M=15

# ── Database ──────────────────────────────────────────────
# PostgreSQL via Prisma. If unset, app shows empty fallback states for live records.
DATABASE_URL=postgresql://user:password@localhost:5432/openrx?schema=public

# ── Blockchain / Wallet ───────────────────────────────────
# Coinbase OnchainKit (get key at https://portal.cdp.coinbase.com/)
NEXT_PUBLIC_ONCHAINKIT_API_KEY=
# Wallet address that receives USDC screening fees and payments
NEXT_PUBLIC_DEVELOPER_WALLET=0xYOUR_WALLET_ADDRESS_HERE
# Optional wallet that should always resolve to the polished demo patient snapshot
OPENRX_DEMO_WALLET=
# Server-side treasury wallet (defaults to above if unset)
OPENRX_TREASURY_WALLET=0xYOUR_WALLET_ADDRESS_HERE
# Privy server credentials for treasury balance lookups and transfers
PRIVY_APP_ID=
PRIVY_APP_SECRET=
OPENRX_TREASURY_PRIVY_WALLET_ID=
# Optional override for Base mainnet USDC token
OPENRX_BASE_USDC_TOKEN=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# ── Payments & Compliance ─────────────────────────────────
# Fallback path used only when Postgres is unreachable or ledger tables are not migrated yet
OPENRX_LEDGER_PATH=./data/openrx-ledger.json
# Fee charged for deep-dive screening (USDC, default: 0.50)
OPENRX_SCREENING_FEE_USDC=0.50
# Wallet that receives screening fees
OPENRX_SCREENING_FEE_WALLET=0xYOUR_WALLET_ADDRESS_HERE

# ── Drug Pricing ──────────────────────────────────────────
# Optional: external drug pricing provider URL and key
# Without these, the app uses FDA OpenData only (no live retail prices)
OPENRX_DRUG_PRICE_PROVIDER_URL=
OPENRX_DRUG_PRICE_PROVIDER_KEY=

# ── Email Notifications ───────────────────────────────────
# Resend API key for transactional emails (falls back to console logging)
# Get your key at https://resend.com/
RESEND_API_KEY=re_...
# Sender used for admin alerts and background digests
OPENRX_EMAIL_FROM="OpenRx <onboarding@resend.dev>"
# Comma-separated admin email addresses for alert notifications
OPENRX_ADMIN_EMAILS=admin@yourpractice.com
# Background-job email mode: off | admins | all
OPENRX_CRON_EMAIL_MODE=admins

# ── OpenClaw Multi-Agent Gateway ─────────────────────────
# WebSocket gateway URL (optional — for advanced multi-channel routing)
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=
# Quality guardrails mode: strict | relaxed (default: strict)
OPENCLAW_QUALITY_MODE=strict
# Optional Vercel deploy hook used by the daily-deploy job
OPENRX_VERCEL_DEPLOY_HOOK_URL=

# ── Auth & Access Control ─────────────────────────────────
# Secret key for admin review tokens (generate with: openssl rand -hex 32)
OPENRX_ADMIN_API_KEY=
# Service token for AWS workers and background dispatch
OPENRX_AGENT_NOTIFY_TOKEN=
# In development, trust the X-Role header for role simulation
OPENRX_TRUST_ROLE_HEADER=false
# Default role when no wallet is connected: patient | admin | clinic_staff
OPENRX_CARE_TEAM_DEFAULT_ROLE=patient
