# Copy the values you need into an external file such as
# $HOME/.config/researcher/live.env and point RESEARCHER_SECRET_CONFIG at it.
# Keep real secrets out of this repo.

# Optional external secret config loader used by the Python CLI.
# RESEARCHER_SECRET_CONFIG=/Users/you/.config/researcher/live.env

# Coinbase
# Prefer *_FILE for live use.
COINBASE_API_KEY_NAME=
COINBASE_API_KEY_NAME_FILE=/Users/you/.config/researcher/coinbase_api_key_name
COINBASE_API_PRIVATE_KEY=
COINBASE_API_PRIVATE_KEY_FILE=/Users/you/.config/researcher/coinbase_private_key.pem
COINBASE_API_BASE_URL=https://api.coinbase.com
COINBASE_TIMEOUT_SECONDS=10

# Kraken
# Prefer *_FILE for live use.
KRAKEN_API_KEY=
KRAKEN_API_KEY_FILE=/Users/you/.config/researcher/kraken_api_key
KRAKEN_API_SECRET=
KRAKEN_API_SECRET_FILE=/Users/you/.config/researcher/kraken_api_secret
KRAKEN_API_OTP=
KRAKEN_API_OTP_FILE=/Users/you/.config/researcher/kraken_api_otp
KRAKEN_API_BASE_URL=https://api.kraken.com
KRAKEN_TIMEOUT_SECONDS=10

# Telegram alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_TOKEN_FILE=/Users/you/.config/researcher/telegram_bot_token
TELEGRAM_CHAT_ID=
TELEGRAM_CHAT_ID_FILE=/Users/you/.config/researcher/telegram_chat_id

# Live trading flags
# Leave these unset in stored files unless you explicitly want a launcher to export them.
RESEARCHER_ENABLE_LIVE_TRADING=
COINBASE_ENABLE_LIVE_TRADING=
KRAKEN_ENABLE_LIVE_TRADING=
