# Research VM environment.
# No exchange secrets should live on this machine.

APP_ROOT=/opt/tao-trader/current
PYTHON_BIN=/opt/tao-trader/venv/bin/python3
HERMES_BIN=/home/taoresearch/.local/bin/hermes

TAO_AUTORESEARCH_DATA_DIR=/var/lib/tao-trader/research/data
TAO_RESEARCH_DATASET=/var/lib/tao-trader/research/data/kraken_tao_usd.json
TAO_RESEARCH_OUTPUT_DIR=/var/lib/tao-trader/research/runs
TAO_RESEARCH_BUDGET_SECONDS=300
TAO_RESEARCH_MAX_CANDIDATES=128
TAO_RESEARCH_SEED=1337
TAO_IMPROVEMENT_STATE=/var/lib/tao-trader/runtime/tao_improvement.db
TAO_IMPROVEMENT_REPORT=/var/lib/tao-trader/output/tao_improvement/latest.json
TAO_IMPROVEMENT_OUTPUT_DIR=/var/lib/tao-trader/output/tao_improvement
TAO_IMPROVEMENT_MIN_OBJECTIVE_DELTA=0.75
TAO_IMPROVEMENT_MIN_RETURN_PCT=0.5
TAO_IMPROVEMENT_MIN_TRADES=10
TAO_IMPROVEMENT_MAX_DRAWDOWN_PCT=8.0
TAO_IMPROVEMENT_MAX_DRAWDOWN_REGRESSION_PCT=1.0

NANOCHAT_ROOT=/opt/nanochat/current
NANOCHAT_REPO_URL=https://github.com/karpathy/nanochat.git
NANOCHAT_BRANCH=master
NANOCHAT_SYNC=0

PYTHONUNBUFFERED=1
