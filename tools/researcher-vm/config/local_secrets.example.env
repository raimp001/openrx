# Example secret-path config.
# Recommended location for the real file:
#   $HOME/.config/researcher/live.env
#
# Point the CLI or launcher at the real file with:
#   export RESEARCHER_SECRET_CONFIG="$HOME/.config/researcher/live.env"
#
# For live trading, keep only *_FILE entries here so the launcher reads all
# credential material from files outside the repo.

COINBASE_API_KEY_NAME_FILE=/Users/you/.config/researcher/coinbase_api_key_name
COINBASE_API_PRIVATE_KEY_FILE=/Users/you/.config/researcher/coinbase_private_key.pem

KRAKEN_API_KEY_FILE=/Users/you/.config/researcher/kraken_api_key
KRAKEN_API_SECRET_FILE=/Users/you/.config/researcher/kraken_api_secret

TELEGRAM_BOT_TOKEN_FILE=/Users/you/.config/researcher/telegram_bot_token
TELEGRAM_CHAT_ID_FILE=/Users/you/.config/researcher/telegram_chat_id

COINBASE_API_BASE_URL=https://api.coinbase.com
KRAKEN_API_BASE_URL=https://api.kraken.com
