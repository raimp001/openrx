# Executor VM environment.
# Store this at /etc/tao-trader/executor.env and keep secrets in
# /etc/tao-trader/live.env plus separate files under /etc/tao-trader/secrets.

APP_ROOT=/opt/tao-trader/current
PYTHON_BIN=/opt/tao-trader/venv/bin/python3

TAO_MODE=paper
TAO_EXCHANGE=kraken
TAO_CONFIG=/opt/tao-trader/current/data/tao_bot.json

TAO_RUNTIME_DB=/var/lib/tao-trader/runtime/tao_live.db
TAO_OUTPUT_DIR=/var/lib/tao-trader/output/tao_bot
TAO_HEARTBEAT_DB=/var/lib/tao-trader/runtime/tao_autopilot.db
TAO_LOOP_JOURNAL_DB=/var/lib/tao-trader/runtime/tao_autopilot.db
TAO_IMPROVEMENT_STATE=/var/lib/tao-trader/runtime/tao_improvement.db

TAO_INTERVAL_SECONDS=900
TAO_PENDING_INTERVAL_SECONDS=60
TAO_ENABLE_RESEARCH=0
TAO_RESEARCH_DATASET=/var/lib/tao-trader/research/data/kraken_tao_usd.json
TAO_RESEARCH_OUTPUT_DIR=/var/lib/tao-trader/research/runs
TAO_RESEARCH_BUDGET_SECONDS=300
TAO_RESEARCH_MAX_CANDIDATES=128
TAO_RESEARCH_SEED=1337
TAO_RESEARCH_EVERY=12

TAO_BACKTEST_REPORT=/var/lib/tao-trader/output/tao_backtest/tao_backtest.json
TAO_DASHBOARD_OUTPUT=/var/lib/tao-trader/output/tao_dashboard/index.html

RESEARCHER_SECRET_CONFIG=/etc/tao-trader/live.env
LIVE_ACK=I_ACCEPT_REAL_TRADES
PYTHONUNBUFFERED=1
